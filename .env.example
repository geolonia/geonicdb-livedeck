# GeonicDB ライブデモ用 API キー（origin 制限あり: localhost:8745 / geolonia.github.io）
# ローカル開発では .env にコピーして実キーを設定する（.env は gitignore 済み）。
# サーバ側のキー/ポリシー名は geonicdb-livedeck- プレフィックスで作成する（README「セットアップ」参照）。
VITE_GEONICDB_READONLY_KEY=gdb_xxxxxxxxxxxxxxxx
VITE_GEONICDB_SURVEY_KEY=gdb_yyyyyyyyyyyyyyyy
# NGSI-LD フィードバックデモ用（キー名 geonicdb-livedeck-feedback / Feedback への POST + WS）
VITE_GEONICDB_FEEDBACK_KEY=gdb_zzzzzzzzzzzzzzzz

# Geolonia Maps の API キー（任意。未設定なら YOUR-API-KEY のままで localhost / github.io は動作）
VITE_GEOLONIA_API_KEY=YOUR-API-KEY
